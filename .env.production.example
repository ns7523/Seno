ENVIRONMENT=production
DATABASE_URL=sqlite:///./agent.db
LOG_LEVEL=INFO

LLM_PROVIDER=groq
SUMMARY_LLM_PROVIDER=default
DRAFTING_LLM_PROVIDER=default
REASONING_LLM_PROVIDER=default
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=30

GMAIL_CLIENT_SECRETS_FILE=/opt/ai-email-agent/secrets/client_secret.json
GMAIL_TOKEN_FILE=/opt/ai-email-agent/secrets/token.json
GMAIL_USER_ID=me
GMAIL_POLL_INTERVAL_SECONDS=60
GMAIL_QUERY=is:unread in:inbox -category:promotions -category:social -in:spam
ENABLE_INBOX_MONITOR=true
GOOGLE_CALENDAR_ENABLED=true
GOOGLE_CALENDAR_ID=primary

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
ADMIN_SECRET=

AUTO_REPLY_RISK_THRESHOLD=55
MIN_AUTO_REPLY_CONFIDENCE=0.75
MAX_EMAIL_BODY_CHARS=8000
PUBLIC_EMAIL=contact@nsakash.in
PERSONAL_EMAIL=nsakash752003@gmail.com
SENDER_ALIASES=contact@nsakash.in,developer@nsakash.in,craftiq@nsakash.in
DEFAULT_SENDER_ALIAS=contact@nsakash.in
DEFAULT_FROM_EMAIL=contact@nsakash.in
REPLY_FROM_ORIGINAL_RECIPIENT=true
ALLOW_SENDER_ALIAS_CONTEXT_OVERRIDE=false
EMAIL_FOOTER_MODE=professional
VECTOR_MEMORY_ENABLED=false
VECTOR_MEMORY_PROVIDER=sqlite
VOICE_TRANSCRIPTION_ENABLED=false

ENABLE_CONTEXTUAL_DRAFTING=true
ENABLE_LONG_EMAIL_REASONING=true
ENABLE_INTENT_EXTRACTION=true
ENABLE_ACTION_ITEM_EXTRACTION=true
TELEGRAM_ENABLE_CALLBACK_LOCKING=true
TELEGRAM_ENABLE_IDEMPOTENCY=true
TELEGRAM_ENABLE_DUPLICATE_PROTECTION=true
TELEGRAM_ENABLE_SAFE_FALLBACKS=true
TELEGRAM_ENABLE_PAYLOAD_TRUNCATION=true
AI_ENABLE_CONTEXT_SUMMARIZATION=true
AI_ENABLE_THREAD_MEMORY=true
AI_ENABLE_RELATIONSHIP_CONTEXT=true
AI_ENABLE_CONVERSATIONAL_REASONING=true
AI_ENABLE_SCHEDULING_REASONING=true
ENABLE_SAFE_WEBHOOK_MODE=true
ENABLE_WEBHOOK_EXCEPTION_GUARD=true
DEBUG_GMAIL_PIPELINE=false
SENO_DEBUG_WORKFLOW=false
